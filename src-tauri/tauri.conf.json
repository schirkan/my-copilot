{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "My Copilot",
  "version": "0.1.0",
  "identifier": "dev.schirkan.mycopilot",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "echo skipping-frontend-build",
    "frontendDist": "../src/dist"
  },
  "app": {
    "windows": [
      {
        "title": "My Copilot",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}